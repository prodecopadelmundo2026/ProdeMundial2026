# Template de variables. Copiar a .env.local para desarrollo local.
# Nunca commitear secretos reales ni valores privados en este archivo.
# Nunca usar service role keys en variables NEXT_PUBLIC_*.

# Supabase del ambiente correspondiente:
# - local/dev: proyecto Supabase DEV
# - Vercel Production: proyecto Supabase PROD
# - Vercel Preview: proyecto Supabase DEV
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Opcional. El login usa el origin del request cuando existe.
# Usar solo como fallback local o para scripts.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Solo server-side. Nunca exponer al cliente.
# No se usa actualmente; no completar salvo que una tarea futura lo requiera.
# SUPABASE_SERVICE_ROLE_KEY=
